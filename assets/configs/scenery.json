      "required_flags": [],
      "forbidden_flags": []
    },
    {
      "id": "SCN_SIL_002",
      "category": "silence",
      "text": "引擎低沉地响着。谁也没说话。",
      "weight": 5,
      "duration": 5,
      "edge_types": [],
      "edge_ids": [],
      "progress_range": [0.3, 0.8],
      "required_flags": [],
      "forbidden_flags": []
    },
    {
      "id": "SCN_SIL_003",
      "category": "silence",
      "text": "窗外的世界在后退。车里很安静。",
      "weight": 5,
      "duration": 5,
